{
    "name":  "ferramenta",
    "version":  "1.0.176",
    "description":  "",
    "main":  "electron/main.js",
    "scripts":  {
                    "test":  "echo \"Error: no test specified\" \u0026\u0026 exit 1",
                    "clean":  "node scripts/clean.js",
                    "clean:all":  "node scripts/clean.js --all",
                    "verify:clean":  "node scripts/verify-clean.js",
                    "dev":  "serve .",
                    "dev:api":  "node server/index.js",
                    "dev:ui":  "cd pwr \u0026\u0026 npm run dev --",
                    "dev:electron":  "set ELECTRON_RUN_AS_NODE=\u0026\u0026 set VITE_DEV_SERVER_URL=http://localhost:5173\u0026\u0026 electron .",
                    "publish:updates":  "powershell -ExecutionPolicy Bypass -File scripts/publish-updates.ps1",
                    "build:ui":  "cd pwr \u0026\u0026 npm run build",
                    "start:electron":  "set ELECTRON_RUN_AS_NODE=\u0026\u0026 electron .",
                    "build:electron":  "npm run build:ui \u0026\u0026 electron-builder --win --x64",
                    "pack:electron":  "npm run build:ui \u0026\u0026 electron-builder --win --x64 --dir",
                    "release:summary":  "node scripts/release-summary.mjs",
                    "release:win":  "powershell -ExecutionPolicy Bypass -File scripts/release-win.ps1"
                },
    "keywords":  [

                 ],
    "author":  "",
    "license":  "ISC",
    "type":  "commonjs",
    "devDependencies":  {
                            "@aws-sdk/client-s3":  "^3.994.0",
                            "electron":  "^33.2.1",
                            "electron-builder":  "^24.13.3",
                            "playwright":  "^1.58.2",
                            "serve":  "^14.2.5"
                        },
    "dependencies":  {
                         "busboy":  "^1.6.0",
                         "cors":  "^2.8.5",
                         "electron-updater":  "^6.1.7",
                         "express":  "^4.19.2",
                         "multer":  "^1.4.5-lts.1",
                         "pdfjs-dist":  "^4.10.38",
                         "playwright-core":  "^1.58.2",
                         "xlsx":  "^0.18.5"
                     },
    "build":  {
                  "appId":  "com.pwr.ferramenta",
                  "productName":  "Ferramenta",
                  "directories":  {
                                      "output":  "dist_electron",
                                      "buildResources":  "electron/resources"
                                  },
                  "files":  [
                                "electron/**",
                                "pwr/dist/**",
                                "server/**",
                                "api/lib/**",
                                "package.json",
                                "!**/.env*",
                                "!**/*.log",
                                "!**/__archive__/**",
                                "!**/legacy/**"
                            ],
                  "asar":  true,
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ]
                          },
                  "nsis":  {
                               "perMachine":  false,
                               "oneClick":  true,
                               "allowElevation":  false
                           },
                  "publish":  [
                                  {
                                      "provider":  "generic",
                                      "url":  "https://s3.sa-east-1.amazonaws.com/ferramenta-updates-937506434821/win/"
                                  }
                              ]
              }
}

